local panel  = component.proxy(component.findComponent("NwPanel1")[1])
local valve1 = component.proxy(component.findComponent("NwSplitterPkgHeavyOilResidue1")[1])
local valve2 = component.proxy(component.findComponent("NwSplitterBlackPowder1")[1])
local valve3 = component.proxy(component.findComponent("NwSplitterSulfur1")[1])
local valve4 = component.proxy(component.findComponent("NwSplitterCoal1")[1])

local cont1  = component.proxy(component.findComponent("NwContainerSmokelessPowder1")[1])
local cont2  = component.proxy(component.findComponent("NwContainerSmokelessPowder2")[1])
local cont3  = component.proxy(component.findComponent("NwContainerCoal1")[1])
local cont4  = component.proxy(component.findComponent("NwContainerCoal2")[1])
local cont5  = component.proxy(component.findComponent("NwContainerSulfur1")[1])
local cont6  = component.proxy(component.findComponent("NwContainerSulfur2")[1])
local cont7  = component.proxy(component.findComponent("NwContainerBlackPowder1")[1])
local cont8  = component.proxy(component.findComponent("NwContainerBlackPowder2")[1])

local btn1     = panel:getModule(1, 1, 0)
local btn2     = panel:getModule(1, 2, 0)
local btn3     = panel:getModule(1, 3, 0)
local btn4     = panel:getModule(1, 4, 0)

local display1 = panel:getModule(2, 1, 0)  -- Oil + Powder throughput
local display2 = panel:getModule(2, 3, 0)  -- Sulfur + Coal throughput
local display3 = panel:getModule(8, 1, 0)  -- SmokelessPowder containers
local display4 = panel:getModule(8, 3, 0)  -- Coal + Sulfur containers

local state = {
    [valve1] = true,
    [valve2] = true,
    [valve3] = true,
    [valve4] = true,
}

local counts = {
    [valve1] = 0,
    [valve2] = 0,
    [valve3] = 0,
    [valve4] = 0,
}

event.listen(btn1)
event.listen(btn2)
event.listen(btn3)
event.listen(btn4)

local function updateColor(btn, splitter)
    if state[splitter] then
        btn:setColor(0, 1, 0, 1)
    else
        btn:setColor(1, 0, 0, 1)
    end
end

local function getItemCount(container)
    return container:getInventories()[1].itemCount
end

local function updateDisplays()
    -- Throughput counts
    display1.text = "Pkg Heavy Oil Residue: "     .. counts[valve1] .. "\nBlack Powder: " .. counts[valve2]
    display2.text = "Sulfur: "  .. counts[valve3] .. "\nCoal: "   .. counts[valve4]

    -- Container counts
    display3.text = "Smokeless Powder CT1: " .. getItemCount(cont1) .. "\nSmokeless Powder CT2: " .. getItemCount(cont2) ..
    				"\nBlack Powder CT1:" .. getItemCount(cont7) .. "\nBlack Powder CT2:" ..getItemCount(cont8)
    display4.text = "Coal CT1: " .. getItemCount(cont3) .. "\nCoal CT2: " .. getItemCount(cont4) ..
                    "\nSulfur CT1: " .. getItemCount(cont5) .. "\nSulfur CT2: " .. getItemCount(cont6)
end

local function processValve(splitter)
    if state[splitter] then
        local item = splitter:getInput()
        if item then
            local result = splitter:transferItem(1)
            if result then
                counts[splitter] = counts[splitter] + 1
            end
        end
    end
end

-- Initial state
display1.size = 24
display2.size = 24
display3.size = 24
display4.size = 24
updateColor(btn1, valve1)
updateColor(btn2, valve2)
updateColor(btn3, valve3)
updateColor(btn4, valve4)
updateDisplays()

print("Valve control active.")

while true do
    local e, sender = event.pull(0.1)

    if e == "Trigger" then
        if sender == btn1 then
            state[valve1] = not state[valve1]
            updateColor(btn1, valve1)
            print("Valve1 (OilResidue): " .. (state[valve1] and "OPEN" or "CLOSED"))
        elseif sender == btn2 then
            state[valve2] = not state[valve2]
            updateColor(btn2, valve2)
            print("Valve2 (BlackPowder): " .. (state[valve2] and "OPEN" or "CLOSED"))
        elseif sender == btn3 then
            state[valve3] = not state[valve3]
            updateColor(btn3, valve3)
            print("Valve3 (Sulfur): " .. (state[valve3] and "OPEN" or "CLOSED"))
        elseif sender == btn4 then
            state[valve4] = not state[valve4]
            updateColor(btn4, valve4)
            print("Valve4 (Coal): " .. (state[valve4] and "OPEN" or "CLOSED"))
        end
    end

    processValve(valve1)
    processValve(valve2)
    processValve(valve3)
    processValve(valve4)
    updateDisplays()
end
